{
  "expo": {
    "name": "Mahala",
    "slug": "mahala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "mahala.qla.dev",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      }
    },
    "ios": {
      "bundleIdentifier": "mahala.qla.dev",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mahala koristi lokaciju da pronadje zonu u kojoj se nalazis.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-screen-orientation",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "68b6f62a-ca7e-4184-b955-74f109f1ecc8"
      }
    },
    "owner": "qla-dev"
  }
}
